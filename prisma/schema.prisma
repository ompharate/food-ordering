datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

generator client {
  provider = "prisma-client-js"
}

model FoodItem {
  FoodItemID  String  @id @default(uuid()) 
  FoodName    String
  Image       String
  Price       Float
  Category    String
  Description String
  
  // Relations
  Review      Review[] 
}

model Customer {
  CustomerID String  @id @default(uuid())
  Name       String
  Email      String  @unique
  Phone      String
  Address    String
  Password   String
  

  Orders     Order[]  
  Reviews    Review[] 
}

model Order {
  OrderID      String   @id @default(uuid())
  OrderDate    DateTime @default(now())
  TotalAmount  Float
  CustomerID   String
  Customer     Customer @relation(fields: [CustomerID], references: [CustomerID])
}

model Review {
  ReviewID     String   @id @default(uuid()) 
  RDescription String
  FoodItemID   String
  CustomerID   String
  FoodItem     FoodItem @relation(fields: [FoodItemID], references: [FoodItemID])
  Customer     Customer @relation(fields: [CustomerID], references: [CustomerID])
}